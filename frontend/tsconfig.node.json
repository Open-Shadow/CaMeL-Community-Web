{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "composite": true,
    "emitDeclarationOnly": true,
    "declaration": true,
    "types": ["node"]
  },
  "include": ["vite.config.ts"]
}
