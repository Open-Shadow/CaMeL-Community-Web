# Django runtime
DJANGO_SETTINGS_MODULE=config.settings.prod
DEBUG=False
SECRET_KEY=replace-with-a-long-random-secret
ALLOWED_HOSTS=your-domain.com,www.your-domain.com
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Database / cache / search (service names from docker compose)
DB_NAME=camel_db
DB_USER=camel
DB_PASSWORD=change-this-db-password
DB_HOST=postgres
DB_PORT=5432
REDIS_URL=redis://redis:6379/0
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_KEY=change-this-meili-key

# Public URLs for email links / social login callbacks
FRONTEND_URL=https://your-domain.com
FRONTEND_EMAIL_VERIFY_URL=https://your-domain.com/verify-email?key={key}
FRONTEND_PASSWORD_RESET_URL=https://your-domain.com/reset-password/{uid}/{token}
FRONTEND_SOCIAL_CALLBACK_URL=https://your-domain.com/auth/social/callback

# Production security (recommended when SSL is enabled on the edge/proxy)
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Optional integrations
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_ENDPOINT_URL=
AWS_S3_CUSTOM_DOMAIN=
SENTRY_DSN=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DEFAULT_FROM_EMAIL=noreply@camel.community
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=10
AUTH_EMAIL_SEND_ASYNC=False
