# Docker Compose variables (used by deploy/docker-compose.prod.yml)
POSTGRES_DB=camel_db
POSTGRES_USER=camel
POSTGRES_PASSWORD=change-this-db-password
MEILI_MASTER_KEY=change-this-meili-key

# Host port exposed by frontend nginx container
FRONTEND_PORT=80

# Frontend build-time variables
VITE_API_URL=/api
VITE_POSTHOG_KEY=
VITE_SENTRY_DSN=
